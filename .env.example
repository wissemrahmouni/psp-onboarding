# Copier vers .env et renseigner les valeurs
# ============================================

# Base de données (backend)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/psp_db

# JWT (min 256 bits = 32 caractères minimum)
JWT_SECRET=changez-moi-minimum-32-caracteres-secret
JWT_REFRESH_SECRET=changez-moi-refresh-minimum-32-caracteres
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (Office 365 / Gmail)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM_EMAIL=noreply@votre-psp.local
SMTP_FROM_NAME=PSP Onboarding

# API Clic to Pay
CLICTOPAY_API_BASE_URL=https://api.clictopay.example.com
CLICTOPAY_API_KEY=

# Application
FRONTEND_URL=https://localhost
PORT=4000

# Chiffrement credentials (distinct de JWT_SECRET)
ENCRYPTION_KEY=changez-moi-32-octets-pour-crypto
