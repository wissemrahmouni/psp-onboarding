{
  "name": "psp-onboarding",
  "private": true,
  "description": "Plateforme Onboarding Marchands PSP",
  "scripts": {
    "dev": "docker-compose up -d && echo 'Lancer backend et frontend en local si besoin'",
    "deploy": "bash scripts/deploy.sh",
    "backup": "bash scripts/backup-db.sh",
    "logs": "docker-compose logs -f",
    "docs:word": "node scripts/generate-api-doc.js",
    "docs:pdf": "node scripts/generate-api-doc-pdf.js",
    "docs": "node scripts/generate-api-doc.js && node scripts/generate-api-doc-pdf.js"
  },
  "devDependencies": {
    "docx": "^9.6.0",
    "puppeteer": "^24.37.5"
  }
}
