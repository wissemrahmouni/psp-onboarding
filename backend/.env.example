# Backend — copier vers .env (ou utiliser le .env à la racine du projet)
# Docker: postgres:5432 | Local: localhost:5432 ou 127.0.0.1:5432
# Si erreur P1000 (auth failed): définir le mot de passe postgres dans PostgreSQL :
#   ALTER USER postgres PASSWORD 'postgres';
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psp_db
JWT_SECRET=changez-moi-minimum-32-caracteres-secret
JWT_REFRESH_SECRET=changez-moi-refresh-minimum-32-caracteres
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM_EMAIL=noreply@votre-psp.local
SMTP_FROM_NAME=PSP Onboarding
CLICTOPAY_API_BASE_URL=https://api.clictopay.example.com
CLICTOPAY_API_KEY=
# Synchronisation getStatus.do — URLs et credentials par environnement (jamais exposés au client)
# URLs optionnelles : si non définies, valeurs par défaut (test.clictopay.com / www.clictopay.com)
CLICTOPAY_TEST_URL=https://test.clictopay.com/epg/rest/merchant/getStatus.do
CLICTOPAY_PROD_URL=https://www.clictopay.com/epg/rest/merchant/getStatus.do
CLICTOPAY_TEST_USERNAME=
CLICTOPAY_TEST_PASSWORD=
CLICTOPAY_PROD_USERNAME=
CLICTOPAY_PROD_PASSWORD=
FRONTEND_URL=https://localhost
PORT=80
# Répertoire des logs de synchronisation ClicToPay (absolu ou relatif à process.cwd())
# Exemple Windows: C:/payment-gateway-sandbox/psp-onboarding/logs
SYNC_LOG_DIR=
ENCRYPTION_KEY=changez-moi-32-octets-pour-crypto
