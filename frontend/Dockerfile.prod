# Build
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# Image finale : contient le build pour copie vers volume partagé avec Nginx
FROM alpine:3.19
RUN apk add --no-cache bash
COPY --from=builder /app/dist /app/dist
# En prod, le volume frontend_dist est monté sur /output ; on copie le build au démarrage
CMD ["sh", "-c", "cp -r /app/dist/. /output/ 2>/dev/null || true && sleep infinity"]
