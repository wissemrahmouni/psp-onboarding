# Frontend - variables optionnelles
# Copier vers .env si besoin de personnaliser

# URL du backend (pour contourner le proxy si envoi email échoue)
# Exemples selon le port du backend :
#   Backend sur 4000 : http://localhost:4000
#   Backend sur 4001 : http://localhost:4001
# VITE_API_URL=

# Cible du proxy Vite (utilisé au build, doit correspondre au backend)
# VITE_PROXY_TARGET=http://localhost:4000
